pdxmesh = {
	name = "male_aresian_eyes_mesh"
	file = "male_eyes.mesh"

	meshsettings = {
		name = "male_eyesShape"
		index = 0
		texture_diffuse ="nda_aresian_eyes_diffuse.dds" # "nda_eyes_red_diffuse" #
		texture_normal = "male_eyes_normal.dds"
		texture_specular = "male_eyes_properties.dds"
		shader = "portrait_eye"
		shader_file = "gfx/FX/jomini/portrait.shader"
	}
}

# aresian Eyes - Stygian - Yigian (based on POD_serp_eyes)
